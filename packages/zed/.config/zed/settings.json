{
    // Appearance
    "theme": "Catppuccin Mocha",
    "ui_font_family": "Berkeley Mono",
    "buffer_font_family": "Berkeley Mono",
    "show_whitespaces": "trailing",

    // Editor
    "tab_size": 4,
    "soft_wrap": "editor_width",
    "diff_view_style": "unified",
    "format_on_save": "on",

    // Terminal
    "terminal": {
        "font_family": "Berkeley Mono",
        "font_fallbacks": ["FiraCode Nerd Font Mono"],
    },

    // AI & Agent
    "agent_servers": {
        "claude-acp": {
            "default_config_options": {
                "model": "default",
                "mode": "acceptEdits",
                "effort": "medium",
            },
            "type": "registry",
        },
        "opencode": {
            "type": "registry",
        },
    },
    "agent": {
        "favorite_models": [
            {
                "provider": "Lumo",
                "model": "lumo-plus-v1",
                "enable_thinking": false,
            },
            {
                "provider": "Lumo",
                "model": "lumo-basic-v1",
                "enable_thinking": false,
            },
        ],
        "default_model": {
            "provider": "Lumo",
            "model": "lumo-plus-v1",
            "enable_thinking": false,
        },
        "button": true,
        "sidebar_side": "right",
        "dock": "right",
        "single_file_review": false,
        "tool_permissions": {
            "default": "allow",
        },
        "default_profile": "write",
    },
    "edit_predictions": {
        "open_ai_compatible_api": {
            "prompt_format": "glm",
            "model": "lumo-plus-v1",
            "api_url": "https://lumo.proton.me/api/ai/v1/chat/completions",
        },
        "allow_data_collection": "no",
        "provider": "zed",
    },
    "language_models": {
        "openai_compatible": {
            "Lumo": {
                "api_url": "https://lumo.proton.me/api/ai/v1",
                "available_models": [
                    {
                        "name": "lumo-plus-v1",
                        "max_tokens": 200000,
                        "max_output_tokens": 32000,
                        "max_completion_tokens": 200000,
                        "capabilities": {
                            "tools": true,
                            "images": true,
                            "parallel_tool_calls": false,
                            "prompt_cache_key": false,
                            "chat_completions": true,
                            "interleaved_reasoning": false,
                            "max_tokens_parameter": false,
                        },
                    },
                    {
                        "name": "lumo-basic-v1",
                        "max_tokens": 266000,
                        "max_output_tokens": 32000,
                        "max_completion_tokens": 266000,
                        "capabilities": {
                            "tools": true,
                            "images": true,
                            "parallel_tool_calls": false,
                            "prompt_cache_key": false,
                            "chat_completions": true,
                            "interleaved_reasoning": false,
                            "max_tokens_parameter": false,
                        },
                    },
                ],
            },
        },
    },

    // Panels & Layout
    "cli_default_open_behavior": "new_window",
    "project_panel": {
        "entry_spacing": "comfortable",
        "hide_gitignore": true,
        "dock": "left",
    },
    "git_panel": {
        "status_style": "icon",
        "dock": "left",
    },
    "debugger": {
        "dock": "bottom",
    },
    "collaboration_panel": {
        "button": false,
    },

    // Language overrides
    "languages": {
        "TypeScript": {
            "code_actions_on_format": { "source.fixAll.eslint": true },
            "formatter": "prettier",
        },
        "TSX": {
            "code_actions_on_format": { "source.fixAll.eslint": true },
            "formatter": "prettier",
        },
        "Astro": {
            "formatter": "prettier",
        },
        "Make": {
            "hard_tabs": true,
        },
        "YAML": {
            "tab_size": 2,
        },
    },
    "lsp": {
        "vtsls": {
            "settings": {
                "typescript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
                "javascript": {
                    "updateImportsOnFileMove": {
                        "enabled": "always",
                    },
                },
            },
            "enable_lsp_tasks": true,
        },
    },

    // Extensions
    "auto_install_extensions": {
        "catppuccin": true,
        "catppuccin-icons": true,
        "fish": true,
        "make": true,
        "emmet": true,
        "scss": true,
        "html": true,
        "toml": true,
    },
}
