{
    "cli_default_open_behavior": "new_window",
    "agent_servers": {
        "claude-acp": {
            "type": "registry",
        },
    },
    "tab_size": 4,
    "soft_wrap": "editor_width",

    "theme": "Catppuccin Mocha",

    "show_whitespaces": "trailing",

    "ui_font_family": "Berkeley Mono",
    "buffer_font_family": "Berkeley Mono",

    "terminal": {
        "font_family": "Berkeley Mono",
        "font_fallbacks": ["FiraCode Nerd Font Mono"],
    },

    "agent": {
        "button": true,
        "sidebar_side": "right",
        "dock": "right",
        "single_file_review": false,
        "tool_permissions": {
            "default": "allow",
        },
        "default_profile": "write",
        "default_model": {
            "enable_thinking": true,
            "provider": "anthropic",
            "model": "claude-sonnet-4-6-latest",
        },
    },

    "edit_predictions": {
        "open_ai_compatible_api": {
            "model": "auto",
            "api_url": "https://lumo.proton.me/api/ai/v1",
            "prompt_format": "glm",
        },
        "provider": "zed",
    },

    "format_on_save": "on",
    "languages": {
        "TypeScript": {
            "code_actions_on_format": { "source.fixAll.eslint": true },
            "formatter": "prettier",
        },
        "TSX": {
            "code_actions_on_format": { "source.fixAll.eslint": true },
            "formatter": "prettier",
        },
        "Make": {
            "hard_tabs": true,
        },
        "YAML": {
            "tab_size": 2,
        },
    },

    // Panel changes
    "project_panel": {
        "entry_spacing": "comfortable",
        "hide_gitignore": true,
        "dock": "left",
    },
    "git_panel": {
        "status_style": "icon",
        "dock": "left",
    },
    "debugger": {
        "dock": "bottom",
    },
    "collaboration_panel": {
        "button": false,
    },

    "auto_install_extensions": {
        "catppuccin": true,
        "catppuccin-icons": true,

        "fish": true,
        "make": true,
        "emmet": true,
        "scss": true,
        "html": true,
        "toml": true,
    },
}
