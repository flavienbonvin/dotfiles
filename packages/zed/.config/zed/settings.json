{
    // Appearance
    "theme": "Catppuccin Mocha",
    "ui_font_family": "Berkeley Mono",
    "buffer_font_family": "Berkeley Mono",
    "show_whitespaces": "trailing",

    // Editor
    "tab_size": 4,
    "soft_wrap": "editor_width",
    "diff_view_style": "unified",
    "format_on_save": "on",

    // Terminal
    "terminal": {
        "font_family": "Berkeley Mono",
        "font_fallbacks": ["FiraCode Nerd Font Mono"],
    },

    // AI & Agent
    "agent_servers": {
        "opencode": {
            "type": "registry",
        },
        "claude-acp": {
            "type": "registry",
        },
    },
    "agent": {
        "default_model": {
            "effort": "high",
            "provider": "zed.dev",
            "model": "claude-sonnet-4-6",
            "enable_thinking": true,
        },
        "button": true,
        "sidebar_side": "right",
        "dock": "right",
        "single_file_review": false,
        "tool_permissions": {
            "default": "allow",
        },
        "default_profile": "write",
    },
    "edit_predictions": {
        "allow_data_collection": "no",
        "provider": "zed",
    },

    // Panels & Layout
    "cli_default_open_behavior": "new_window",
    "project_panel": {
        "entry_spacing": "comfortable",
        "hide_gitignore": true,
        "dock": "left",
    },
    "git_panel": {
        "status_style": "icon",
        "dock": "left",
    },
    "debugger": {
        "dock": "bottom",
    },
    "collaboration_panel": {
        "button": false,
    },

    // Language overrides
    "languages": {
        "TypeScript": {
            "code_actions_on_format": { "source.fixAll.eslint": true },
            "formatter": "prettier",
        },
        "TSX": {
            "code_actions_on_format": { "source.fixAll.eslint": true },
            "formatter": "prettier",
        },
        "Astro": {
            "formatter": "prettier",
        },
        "Make": {
            "hard_tabs": true,
        },
        "YAML": {
            "tab_size": 2,
        },
    },

    // Extensions
    "auto_install_extensions": {
        "catppuccin": true,
        "catppuccin-icons": true,
        "fish": true,
        "make": true,
        "emmet": true,
        "scss": true,
        "html": true,
        "toml": true,
    },
}
