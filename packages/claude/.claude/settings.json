    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "rtk hook claude"
                    }
                ]
            }
        ]
    },
    "statusLine": {
        "type": "command",
        "command": "~/.claude/statusline.sh",
        "padding": 2
    },
    "enabledPlugins": {
        "typescript-lsp@claude-plugins-official": true,
        "figma@claude-plugins-official": true
    },
    "effortLevel": "medium"
