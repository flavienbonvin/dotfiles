{
    "model": "sonnet[1m]",
    "effortLevel": "medium",

    "statusLine": {
        "type": "command",
        "command": "~/.claude/statusline.sh",
        "padding": 2
    },

    "enabledPlugins": {
        "typescript-lsp@claude-plugins-official": true
    },

    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "rtk hook claude"
                    }
                ]
            }
        ]
    }
}
